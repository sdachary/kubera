<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-8">Dividend SIP Planner</h1>
  
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div>
      <%= render DividendSip::CalculatorComponent.new(monthly_investment: @monthly_investment, target_income: @target_income) %>
    </div>
    
    <div id="dividend_sip_results">
      <!-- Results will be loaded here via Stimulus -->
      <div class="bg-gray-50 rounded-lg p-8 text-center text-gray-500">
        Enter your details to see projections and stock suggestions.
      </div>
    </div>
  </div>
</div>
