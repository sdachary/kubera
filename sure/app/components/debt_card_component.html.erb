<div class="bg-surface border border-subtle rounded-xl p-5 shadow-sm hover:shadow-md transition-all duration-200">
  <div class="flex justify-between items-start mb-5">
    <div class="flex items-center gap-3">
      <div class="p-2.5 rounded-xl" style="background-color: <%= hex_with_alpha(icon_color, 0.1) %>">
        <%= helpers.icon icon, class: "w-5 h-5", style: "color: #{icon_color}" %>
      </div>
      <div>
        <h3 class="font-bold text-primary leading-tight mb-0.5"><%= name %></h3>
        <p class="text-xs text-secondary font-semibold uppercase tracking-wider"><%= subtype_label %></p>
      </div>
    </div>
    <div class="text-right">
      <div class="text-lg font-black text-primary leading-tight mb-0.5"><%= balance %></div>
      <div class="text-[10px] text-secondary font-bold uppercase tracking-widest">Remaining</div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3 mb-6">
    <div class="bg-surface-inset rounded-xl p-3 border border-subtle">
      <div class="text-[10px] text-secondary uppercase font-black mb-1 tracking-tight">Interest Rate</div>
      <div class="text-sm font-bold text-primary"><%= interest_rate %></div>
    </div>
    <div class="bg-surface-inset rounded-xl p-3 border border-subtle">
      <div class="text-[10px] text-secondary uppercase font-black mb-1 tracking-tight">Monthly EMI</div>
      <div class="text-sm font-bold text-primary"><%= emi %></div>
    </div>
  </div>

  <div class="space-y-2.5">
    <div class="flex justify-between items-end">
      <span class="text-[11px] font-bold text-secondary uppercase tracking-wide">Payoff Progress</span>
      <span class="text-xs font-black text-indigo-600"><%= progress %>%</span>
    </div>
    <div class="w-full bg-surface-inset rounded-full h-2.5 overflow-hidden">
      <div class="bg-indigo-500 h-full rounded-full transition-all duration-700 ease-out" style="width: <%= progress %>%"></div>
    </div>
  </div>
</div>
