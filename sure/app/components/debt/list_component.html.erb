<div class="space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
    <div>
      <h2 class="text-2xl font-black text-gray-900 tracking-tight">Debt Overview</h2>
      <p class="text-gray-500 font-medium">You have <%= loans.count %> active <%= "debt".pluralize(loans.count) %>.</p>
    </div>
    
    <div class="flex gap-8">
      <div>
        <div class="text-[10px] text-gray-400 uppercase font-black tracking-widest mb-1">Total Debt</div>
        <div class="text-xl font-black text-gray-900"><%= total_debt %></div>
      </div>
      <div class="border-l border-gray-100 pl-8">
        <div class="text-[10px] text-gray-400 uppercase font-black tracking-widest mb-1">Avg. Rate</div>
        <div class="text-xl font-black text-indigo-600"><%= average_interest_rate %></div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
    <% loans.each do |loan| %>
      <%= render Debt::CardComponent.new(loan: loan) %>
    <% end %>
  </div>
</div>
