<div class="bg-surface border border-subtle rounded-xl p-4 shadow-sm hover:shadow-md transition-shadow">
  <div class="flex justify-between items-start mb-4">
    <div class="flex items-center gap-3">
      <div class="p-2 rounded-lg" style="background-color: <%= hex_with_alpha(icon_color, 0.1) %>">
        <%= helpers.icon icon, class: "w-5 h-5", style: "color: #{icon_color}" %>
      </div>
      <div>
        <h3 class="font-bold text-gray-900 leading-none mb-1"><%= name %></h3>
        <p class="text-xs text-gray-500 font-medium uppercase tracking-wider"><%= loan.subtype.titleize %></p>
      </div>
    </div>
    <div class="text-right">
      <div class="text-lg font-bold text-gray-900 leading-none mb-1"><%= balance %></div>
      <div class="text-xs text-gray-500 font-medium uppercase tracking-wider">Remaining</div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-6">
    <div class="bg-gray-50 rounded-lg p-2">
      <div class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-tight">Interest Rate</div>
      <div class="text-sm font-bold text-gray-800"><%= interest_rate %></div>
    </div>
    <div class="bg-gray-50 rounded-lg p-2">
      <div class="text-[10px] text-gray-500 uppercase font-bold mb-1 tracking-tight">Monthly EMI</div>
      <div class="text-sm font-bold text-gray-800"><%= emi %></div>
    </div>
  </div>

  <div class="space-y-2">
    <div class="flex justify-between items-end">
      <span class="text-xs font-bold text-gray-600">Payoff Progress</span>
      <span class="text-xs font-black text-indigo-600"><%= progress %>%</span>
    </div>
    <div class="w-full bg-gray-100 rounded-full h-2 overflow-hidden">
      <div class="bg-indigo-500 h-full rounded-full transition-all duration-500" style="width: <%= progress %>%"></div>
    </div>
  </div>
</div>
