<div class="bg-white shadow rounded-lg p-6" data-controller="dividend-sip">
  <form data-action="submit->dividend-sip#calculate">
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">Monthly Investment (₹)</label>
      <input type="number" 
             name="monthly_investment" 
             value="<%= @monthly_investment %>" 
             data-dividend-sip-target="monthlyInvestment"
             class="w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary">
    </div>

    <div class="mb-6">
      <label class="block text-sm font-medium text-gray-700 mb-1">Target Monthly Dividend Income (₹)</label>
      <input type="number" 
             name="target_income" 
             value="<%= @target_income %>" 
             data-dividend-sip-target="targetIncome"
             class="w-full border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary">
    </div>

    <%= render DS::Button.new(type: :submit, variant: :primary, class: "w-full") do %>
      Calculate SIP Plan
    <% end %>
  </form>
</div>
