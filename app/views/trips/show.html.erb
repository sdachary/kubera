<% content_for :title, "#{@trip.name} - Kubera" %>

<div class="min-h-screen bg-slate-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <%# Header %>
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
      <div>
        <div class="flex items-center gap-2 mb-1">
          <%= link_to trips_path, class: "text-slate-400 hover:text-slate-300 transition-colors" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          <% end %>
        </div>
        <div class="flex items-center gap-3">
          <h1 class="text-2xl font-bold text-slate-100"><%= @trip.name %></h1>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @trip.status == 'active' ? 'bg-emerald-900/40 text-emerald-300 border border-emerald-800/40' : @trip.status == 'settled' ? 'bg-blue-900/40 text-blue-300 border border-blue-800/40' : 'bg-slate-800/40 text-slate-400 border border-slate-700/40' %>">
            <%= @trip.status.capitalize %>
          </span>
        </div>
        <div class="flex flex-wrap items-center gap-3 mt-1 text-sm text-slate-400">
          <% if @trip.destination.present? %>
            <span><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline mr-1 -mt-0.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><%= @trip.destination %></span>
          <% end %>
          <% if @trip.start_date %>
            <span><%= @trip.start_date.strftime("%b %d") %><%= " - #{@trip.end_date.strftime("%b %d, %Y")}" if @trip.end_date %></span>
          <% end %>
          <span><%= @trip.trip_members.count %> member<%= 's' if @trip.trip_members.count != 1 %></span>
          <span class="text-teal-400">₹<%= format("%.0f", @trip.total_spent) %> spent</span>
        </div>
      </div>

      <% if @trip.can_settle? %>
        <div class="flex items-center gap-2">
          <%= link_to edit_trip_path(@trip), class: "px-3 py-2 text-sm text-slate-400 hover:text-slate-300 border border-slate-700/50 rounded-lg transition-colors" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline mr-1 -mt-0.5"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
            Edit
          <% end %>
          <%= button_to archive_trip_path(@trip), method: :post, class: "px-3 py-2 text-sm text-slate-400 hover:text-slate-300 border border-slate-700/50 rounded-lg transition-colors", data: { confirm: "Archive this trip?" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline mr-1 -mt-0.5"><path d="M21 8v13H3V8"/><path d="M1 3h22v5H1z"/></svg>
            Archive
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Flash messages %>
    <% if flash[:notice] %>
      <div class="mb-6 p-3 bg-emerald-900/30 border border-emerald-800/50 rounded-lg text-emerald-200 text-sm"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="mb-6 p-3 bg-red-900/30 border border-red-800/50 rounded-lg text-red-200 text-sm"><%= flash[:alert] %></div>
    <% end %>

    <div class="grid gap-6 lg:grid-cols-3">
      <%# Left column: Members + Budget %>
      <div class="space-y-6 lg:col-span-1">
        <%# Members %>
        <div class="bg-slate-900/70 border border-slate-800/50 rounded-xl p-5">
          <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-4">Members</h2>

          <% if @trip.trip_members.any? %>
            <div class="space-y-2 mb-4">
              <% @trip.trip_members.each do |member| %>
                <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-slate-800/30 group">
                  <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-full bg-teal-900/40 flex items-center justify-center text-xs font-medium text-teal-300">
                      <%= member.name.first.upcase %>
                    </div>
                    <div>
                      <p class="text-sm text-slate-200"><%= member.name %></p>
                      <% if member.email.present? %>
                        <p class="text-xs text-slate-500"><%= member.email %></p>
                      <% end %>
                    </div>
                  </div>
                  <div class="flex items-center gap-2">
                    <% balance = @balances[member.id].to_f %>
                    <span class="text-xs font-medium <%= balance > 0 ? 'text-emerald-400' : balance < 0 ? 'text-red-400' : 'text-slate-500' %>">
                      <%= balance > 0 ? '+' : '' %>₹<%= format("%.0f", balance) %>
                    </span>
                    <%= button_to trip_member_path(@trip, member), method: :delete, class: "opacity-0 group-hover:opacity-100 text-slate-500 hover:text-red-400 transition-all", data: { confirm: "Remove #{member.name}?" } do %>
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>

          <%= form_with model: [@trip, @trip_member], class: "flex gap-2" do |f| %>
            <%= f.text_field :name, placeholder: "Add member...", class: "flex-1 rounded-lg border border-slate-700/50 bg-slate-800/50 px-3 py-2 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
            <%= f.submit "Add", class: "px-3 py-2 bg-teal-600 hover:bg-teal-500 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
          <% end %>
        </div>

        <%# Budget vs Actual %>
        <% if @budget_vs_actual.any? %>
          <div class="bg-slate-900/70 border border-slate-800/50 rounded-xl p-5">
            <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-4">Budget vs Actual</h2>
            <div class="space-y-3">
              <% @budget_vs_actual.each do |item| %>
                <div>
                  <div class="flex items-center justify-between text-sm mb-1">
                    <span class="flex items-center gap-1.5">
                      <span class="w-2.5 h-2.5 rounded-full" style="background-color: <%= item[:category].color %>"></span>
                      <span class="text-slate-300"><%= item[:category].name %></span>
                    </span>
                    <span class="text-xs text-slate-400">₹<%= format("%.0f", item[:spent]) %><%= " / ₹#{format('%.0f', item[:budget])}" if item[:budget] > 0 %></span>
                  </div>
                  <% if item[:budget] > 0 %>
                    <div class="w-full h-1.5 bg-slate-800 rounded-full overflow-hidden">
                      <div class="h-full rounded-full transition-all <%= item[:spent] > item[:budget] ? 'bg-red-500' : 'bg-teal-500' %>" style="width: <%= [item[:spent] / item[:budget] * 100, 100].min %>%"></div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# Right column: Expenses + Balances + Settlements %>
      <div class="space-y-6 lg:col-span-2">
        <%# Add Expense Form %>
        <% if @trip.trip_members.any? && @trip.can_settle? %>
          <div class="bg-slate-900/70 border border-slate-800/50 rounded-xl p-5">
            <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-4">Add Expense</h2>
            <%= form_with model: [@trip, @trip_expense], class: "grid gap-4 sm:grid-cols-2" do |f| %>
              <div>
                <%= f.label :description, "Description", class: "block text-xs font-medium text-slate-400 mb-1" %>
                <%= f.text_field :description, required: true, placeholder: "Dinner at beach shack", class: "w-full rounded-lg border border-slate-700/50 bg-slate-800/50 px-3 py-2 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
              </div>
              <div>
                <%= f.label :amount, "Amount", class: "block text-xs font-medium text-slate-400 mb-1" %>
                <%= f.number_field :amount, required: true, step: "0.01", min: 0.01, placeholder: "2500", class: "w-full rounded-lg border border-slate-700/50 bg-slate-800/50 px-3 py-2 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
              </div>
              <div>
                <%= f.label :trip_member_id, "Paid by", class: "block text-xs font-medium text-slate-400 mb-1" %>
                <%= f.collection_select :trip_member_id, @trip.trip_members, :id, :name, { prompt: "Who paid?" }, { required: true, class: "w-full rounded-lg border border-slate-700/50 bg-slate-800/50 px-3 py-2 text-sm text-slate-200 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" } %>
              </div>
              <div>
                <%= f.label :trip_category_id, "Category", class: "block text-xs font-medium text-slate-400 mb-1" %>
                <%= f.collection_select :trip_category_id, @trip.trip_categories, :id, :name, { prompt: "Select category" }, { class: "w-full rounded-lg border border-slate-700/50 bg-slate-800/50 px-3 py-2 text-sm text-slate-200 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" } %>
              </div>
              <div>
                <%= f.label :split_type, "Split type", class: "block text-xs font-medium text-slate-400 mb-1" %>
                <%= f.select :split_type, options_for_select([["Equal", "equal"], ["Percentage", "percentage"], ["Custom", "custom"]], "equal"), {}, { class: "w-full rounded-lg border border-slate-700/50 bg-slate-800/50 px-3 py-2 text-sm text-slate-200 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" } %>
              </div>
              <div>
                <%= f.label :expense_date, "Date", class: "block text-xs font-medium text-slate-400 mb-1" %>
                <%= f.date_field :expense_date, value: Date.current, class: "w-full rounded-lg border border-slate-700/50 bg-slate-800/50 px-3 py-2 text-sm text-slate-200 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
              </div>
              <div class="sm:col-span-2">
                <%= f.submit "Add Expense", class: "w-full px-4 py-2.5 bg-teal-600 hover:bg-teal-500 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Settlement Form %>
        <% if @trip.can_settle? && @trip.trip_members.count >= 2 %>
          <% debtor = nil %>
          <% creditor = nil %>
          <% @balances.each do |member_id, bal| %>
            <% if bal < 0 && debtor.nil? %><% debtor = @trip.trip_members.find(member_id) %><% end %>
            <% if bal > 0 && creditor.nil? %><% creditor = @trip.trip_members.find(member_id) %><% end %>
          <% end %>
          <% if debtor && creditor %>
            <div class="bg-slate-900/70 border border-slate-800/50 rounded-xl p-5">
              <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-4">Quick Settle</h2>
              <p class="text-sm text-slate-400 mb-3">
                <span class="text-red-400"><%= debtor.name %></span> owes
                <span class="text-emerald-400"><%= creditor.name %></span>
                ₹<%= format("%.0f", @balances[creditor.id].abs) %>
              </p>
              <%= form_with model: [@trip, TripSettlement.new], class: "flex gap-2" do |f| %>
                <%= f.hidden_field :from_trip_member_id, value: debtor.id %>
                <%= f.hidden_field :to_trip_member_id, value: creditor.id %>
                <%= f.number_field :amount, value: [@balances[creditor.id].abs, @balances[debtor.id].abs].min.round(2), step: "0.01", class: "flex-1 rounded-lg border border-slate-700/50 bg-slate-800/50 px-3 py-2 text-sm text-slate-200 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
                <%= f.submit "Settle", class: "px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
              <% end %>
            </div>
          <% end %>
        <% end %>

        <%# Balances Summary %>
        <div class="bg-slate-900/70 border border-slate-800/50 rounded-xl p-5">
          <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-4">Who owes what</h2>
          <% if @balances.values.all? { |b| b == 0 } %>
            <p class="text-sm text-slate-500 text-center py-4">All settled up!</p>
          <% else %>
            <div class="space-y-2">
              <% @trip.trip_members.each do |member| %>
                <% bal = @balances[member.id].to_f %>
                <div class="flex items-center justify-between px-3 py-2 rounded-lg <%= bal > 0 ? 'bg-emerald-900/20 border border-emerald-800/30' : bal < 0 ? 'bg-red-900/20 border border-red-800/30' : 'bg-slate-800/30' %>">
                  <span class="text-sm text-slate-200"><%= member.name %></span>
                  <span class="text-sm font-medium <%= bal > 0 ? 'text-emerald-400' : bal < 0 ? 'text-red-400' : 'text-slate-500' %>">
                    <%= bal > 0 ? "Gets ₹#{format('%.0f', bal)}" : bal < 0 ? "Owes ₹#{format('%.0f', bal.abs)}" : "Settled" %>
                  </span>
                </div>
              <% end %>
            </div>
            <% if @trip.can_settle? && @balances.values.all? { |b| b == 0 || b.abs < 0.01 } %>
              <div class="mt-4">
                <%= button_to settle_trip_path(@trip), method: :post, class: "w-full px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-medium transition-colors", data: { confirm: "Mark this trip as fully settled?" } do %>
                  Mark Trip as Settled
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>

        <%# Expenses %>
        <div class="bg-slate-900/70 border border-slate-800/50 rounded-xl p-5">
          <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-4">Expenses</h2>
          <% if @expenses.empty? %>
            <p class="text-sm text-slate-500 text-center py-4">No expenses yet. Add one above!</p>
          <% else %>
            <div class="space-y-2">
              <% @expenses.each do |expense| %>
                <div class="flex items-start justify-between px-3 py-3 rounded-lg bg-slate-800/30 group">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                      <span class="text-sm font-medium text-slate-200"><%= expense.description %></span>
                      <% if expense.trip_category %>
                        <span class="w-2 h-2 rounded-full" style="background-color: <%= expense.trip_category.color %>"></span>
                      <% end %>
                    </div>
                    <div class="flex items-center gap-3 mt-1 text-xs text-slate-500">
                      <span>Paid by <%= expense.trip_member.name %></span>
                      <span><%= expense.split_type.capitalize %></span>
                      <% if expense.expense_date %>
                        <span><%= expense.expense_date.strftime("%b %d") %></span>
                      <% end %>
                    </div>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <span class="text-sm font-medium text-slate-200">₹<%= format("%.0f", expense.amount) %></span>
                    <%= button_to trip_expense_path(@trip, expense), method: :delete, class: "opacity-0 group-hover:opacity-100 text-slate-500 hover:text-red-400 transition-all", data: { confirm: "Delete this expense?" } do %>
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <%# Settlements %>
        <% if @settlements.any? %>
          <div class="bg-slate-900/70 border border-slate-800/50 rounded-xl p-5">
            <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wider mb-4">Settlements</h2>
            <div class="space-y-2">
              <% @settlements.each do |settlement| %>
                <div class="flex items-center justify-between px-3 py-2 rounded-lg bg-slate-800/30">
                  <div class="flex items-center gap-2 text-sm">
                    <span class="text-slate-200"><%= settlement.from_member.name %></span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-teal-400"><path d="m5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    <span class="text-slate-200"><%= settlement.to_member.name %></span>
                  </div>
                  <span class="text-sm font-medium text-emerald-400">₹<%= format("%.0f", settlement.amount) %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
