<%= form_with model: trip, class: "space-y-6" do |f| %>
  <% if trip.errors.any? %>
    <div class="bg-red-900/30 border border-red-800/50 rounded-lg p-4">
      <ul class="list-disc list-inside text-sm text-red-200 space-y-1">
        <% trip.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-6 sm:grid-cols-2">
    <div class="sm:col-span-2">
      <%= f.label :name, "Trip name", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
      <%= f.text_field :name, required: true, placeholder: "Goa Trip 2026", class: "w-full rounded-lg border border-slate-700/50 bg-slate-900/50 px-3 py-2.5 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
    </div>

    <div>
      <%= f.label :destination, "Destination", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
      <%= f.text_field :destination, placeholder: "Goa, India", class: "w-full rounded-lg border border-slate-700/50 bg-slate-900/50 px-3 py-2.5 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
    </div>

    <div>
      <%= f.label :group_type, "Group type", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
      <%= f.select :group_type, options_for_select(Trip::GROUP_TYPES.map { |t| [t.capitalize, t] }, trip.group_type), {}, class: "w-full rounded-lg border border-slate-700/50 bg-slate-900/50 px-3 py-2.5 text-sm text-slate-200 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
    </div>

    <div>
      <%= f.label :start_date, "Start date", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
      <%= f.date_field :start_date, class: "w-full rounded-lg border border-slate-700/50 bg-slate-900/50 px-3 py-2.5 text-sm text-slate-200 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
    </div>

    <div>
      <%= f.label :end_date, "End date", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
      <%= f.date_field :end_date, class: "w-full rounded-lg border border-slate-700/50 bg-slate-900/50 px-3 py-2.5 text-sm text-slate-200 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
    </div>

    <div>
      <%= f.label :currency, "Currency", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
      <%= f.select :currency, options_for_select([["INR (₹)", "INR"], ["USD ($)", "USD"], ["EUR (€)", "EUR"], ["GBP (£)", "GBP"]], trip.currency), {}, class: "w-full rounded-lg border border-slate-700/50 bg-slate-900/50 px-3 py-2.5 text-sm text-slate-200 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
    </div>

    <div>
      <%= f.label :total_budget, "Total budget", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
      <%= f.number_field :total_budget, step: "0.01", min: 0, placeholder: "50000", class: "w-full rounded-lg border border-slate-700/50 bg-slate-900/50 px-3 py-2.5 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20" %>
    </div>
  </div>

  <div>
    <%= f.label :notes, "Notes", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
    <%= f.text_area :notes, rows: 3, placeholder: "Any additional details about the trip...", class: "w-full rounded-lg border border-slate-700/50 bg-slate-900/50 px-3 py-2.5 text-sm text-slate-200 placeholder-slate-500 focus:outline-none focus:border-teal-500/50 focus:ring-1 focus:ring-teal-500/20 resize-none" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "px-6 py-2.5 bg-teal-600 hover:bg-teal-500 text-white rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
    <%= link_to "Cancel", trips_path, class: "text-sm text-slate-400 hover:text-slate-300 transition-colors" %>
  </div>
<% end %>
