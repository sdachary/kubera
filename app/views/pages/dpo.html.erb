<% content_for :title, "Data Protection Officer - Kubera" %>

<div class="max-w-3xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
  <div class="flex items-center justify-between mb-10">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 rounded-xl bg-teal-600 flex items-center justify-center text-white font-bold text-sm">K</div>
      <div>
        <h1 class="text-2xl font-bold tracking-tight text-white">Data Protection Officer</h1>
        <p class="text-slate-400 text-sm mt-0.5">DPDP Act 2023 compliance</p>
      </div>
    </div>
    <%= link_to root_path, class: "flex items-center gap-1.5 text-sm text-slate-400 hover:text-slate-200 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Dashboard
    <% end %>
  </div>

  <div class="space-y-8">
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 sm:p-8 space-y-8">
      <div>
        <h2 class="text-lg font-semibold text-white mb-2">Contact</h2>
        <p class="text-slate-300 text-sm">
          For all data protection inquiries, including requests to access, correct, or delete your personal data:
        </p>
        <p class="mt-3 text-teal-400 font-medium text-sm">
          DPO: <a href="mailto:dpo@kubera.app" class="underline hover:text-teal-300">dpo@kubera.app</a>
        </p>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-white mb-3">Your Rights Under DPDP Act 2023</h2>
        <ul class="text-slate-300 text-sm space-y-2.5">
          <li class="flex items-start gap-2.5"><span class="text-teal-400 mt-0.5 shrink-0">&#8226;</span><span><strong class="text-slate-200">Right to知情 (Knowledge):</strong> You have the right to know what personal data we collect and how it is used.</span></li>
          <li class="flex items-start gap-2.5"><span class="text-teal-400 mt-0.5 shrink-0">&#8226;</span><span><strong class="text-slate-200">Right to Consent:</strong> We will obtain your explicit consent before processing your data for any purpose.</span></li>
          <li class="flex items-start gap-2.5"><span class="text-teal-400 mt-0.5 shrink-0">&#8226;</span><span><strong class="text-slate-200">Right to Access:</strong> You can request a copy of all personal data we hold about you.</span></li>
          <li class="flex items-start gap-2.5"><span class="text-teal-400 mt-0.5 shrink-0">&#8226;</span><span><strong class="text-slate-200">Right to Correction:</strong> You can request correction of inaccurate or incomplete data.</span></li>
          <li class="flex items-start gap-2.5"><span class="text-teal-400 mt-0.5 shrink-0">&#8226;</span><span><strong class="text-slate-200">Right to Deletion:</strong> You can request deletion of your personal data at any time with a 48-hour cancellation window.</span></li>
          <li class="flex items-start gap-2.5"><span class="text-teal-400 mt-0.5 shrink-0">&#8226;</span><span><strong class="text-slate-200">Right to Grievance Redressal:</strong> You can file complaints regarding data processing.</span></li>
        </ul>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-white mb-3">Data We Collect</h2>
        <ul class="text-slate-300 text-sm space-y-2">
          <li class="flex items-start gap-2.5"><span class="text-teal-400 mt-0.5 shrink-0">&#8226;</span><span>Email address and profile information (via Google/GitHub OAuth)</span></li>
          <li class="flex items-start gap-2.5"><span class="text-teal-400 mt-0.5 shrink-0">&#8226;</span><span>Financial data you choose to enter (debts, investments, transactions, budgets)</span></li>
          <li class="flex items-start gap-2.5"><span class="text-teal-400 mt-0.5 shrink-0">&#8226;</span><span>Usage data to improve our services</span></li>
        </ul>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-white mb-2">Data Retention</h2>
        <p class="text-slate-300 text-sm">
          We retain your data only as long as necessary to provide our services. Upon account deletion, all personal data is permanently erased within 48 hours.
        </p>
      </div>
    </div>

    <%# Grievance Form %>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 sm:p-8" data-controller="privacy-settings">
      <h2 class="text-lg font-semibold text-white mb-1">File a Grievance</h2>
      <p class="text-sm text-slate-400 mb-6">Submit a formal grievance under Section 14 of the DPDP Act 2023. We will acknowledge receipt within 24 hours and resolve within 90 days.</p>

      <form id="dpo-grievance-form" class="space-y-4" data-action="submit->privacy-settings#submitGrievance">
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-1.5">Grievance Type</label>
          <select name="grievance_type" required class="w-full rounded-lg border border-slate-700 bg-slate-800/50 px-3.5 py-2.5 text-white text-sm focus:border-teal-500 focus:ring-1 focus:ring-teal-500 outline-none transition-colors">
            <option value="">Select type...</option>
            <option value="access">Cannot access my data</option>
            <option value="correction">Data correction needed</option>
            <option value="erasure">Deletion request issue</option>
            <option value="consent">Consent concern</option>
            <option value="breach">Suspected data breach</option>
            <option value="marketing">Unwanted marketing</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-1.5">Your Name</label>
          <input type="text" name="name" required class="w-full rounded-lg border border-slate-700 bg-slate-800/50 px-3.5 py-2.5 text-white text-sm placeholder-slate-500 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 outline-none transition-colors">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-1.5">Email</label>
          <input type="email" name="email" required class="w-full rounded-lg border border-slate-700 bg-slate-800/50 px-3.5 py-2.5 text-white text-sm placeholder-slate-500 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 outline-none transition-colors">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-1.5">Phone (optional)</label>
          <input type="tel" name="phone" placeholder="+91XXXXXXXXXX" class="w-full rounded-lg border border-slate-700 bg-slate-800/50 px-3.5 py-2.5 text-white text-sm placeholder-slate-500 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 outline-none transition-colors">
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-300 mb-1.5">Description</label>
          <textarea name="description" rows="4" required placeholder="Describe your concern in detail..." class="w-full rounded-lg border border-slate-700 bg-slate-800/50 px-3.5 py-2.5 text-white text-sm placeholder-slate-500 focus:border-teal-500 focus:ring-1 focus:ring-teal-500 outline-none transition-colors"></textarea>
        </div>
        <button type="submit" class="px-5 py-2.5 text-sm font-medium text-white bg-teal-600 hover:bg-teal-500 rounded-lg transition-colors cursor-pointer">
          Submit Grievance
        </button>
        <p id="dpo-grievance-result" class="hidden text-sm mt-2"></p>
      </form>
    </div>
  </div>
</div>
