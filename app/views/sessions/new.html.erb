<% content_for :title, "Sign in - Kubera" %>

<div class="min-h-screen flex items-center justify-center bg-gray-950 px-4">
  <div class="max-w-md w-full space-y-8">
    <div class="text-center">
      <h1 class="text-4xl font-bold text-white">Kubera</h1>
      <p class="mt-2 text-gray-400">Your financial freedom companion</p>
    </div>

    <div class="bg-gray-900 rounded-2xl p-8 shadow-xl border border-gray-800">
      <% if flash[:alert] %>
        <div class="mb-4 p-3 bg-red-900/50 border border-red-800 rounded-lg text-red-200 text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <% if flash[:notice] %>
        <div class="mb-4 p-3 bg-green-900/50 border border-green-800 rounded-lg text-green-200 text-sm">
          <%= flash[:notice] %>
        </div>
      <% end %>

      <p class="text-gray-300 text-sm mb-6 text-center">
        Sign in with your Google account to get started.
      </p>

      <%= button_to '/auth/google_oauth2/callback', method: :post, class: "w-full flex items-center justify-center gap-3 bg-white hover:bg-gray-100 text-gray-900 font-medium rounded-lg px-6 py-3 transition-colors" do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Sign in with Google
      <% end %>

      <div class="mt-6 text-center">
        <p class="text-xs text-gray-500">
          By signing in, you agree to our
          <%= link_to "Privacy Policy", privacy_path, class: "underline hover:text-gray-400" %>
          and
          <%= link_to "Terms of Service", terms_path, class: "underline hover:text-gray-400" %>.
        </p>
        <p class="text-xs text-gray-600 mt-2">
          This service is intended for users aged 18 and above. If you are under 18, please do not use this service.
        </p>
      </div>
    </div>

    <p class="text-center text-xs text-gray-600">
      Questions? Contact our
      <%= link_to "DPO", dpo_path, class: "underline hover:text-gray-400" %>
    </p>
  </div>
</div>
