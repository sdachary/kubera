<% content_for :title, "Forgot password - Kubera" %>

<div class="min-h-screen flex flex-col lg:flex-row">
  <%# Brand panel %>
  <div class="lg:w-1/2 bg-slate-950 p-8 lg:p-16 flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-teal-500/10 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-lg">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl bg-teal-600 flex items-center justify-center text-white font-bold text-lg">K</div>
        <span class="text-xl font-semibold tracking-tight text-white">Kubera</span>
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tighter text-white leading-[1.1]">
        Forgot<br>
        <span class="text-teal-400">your password?</span>
      </h1>
      <p class="mt-4 text-lg text-slate-400 leading-relaxed max-w-md">
        No worries. Enter your email and we'll send you a reset link.
      </p>
    </div>
  </div>

  <%# Form panel %>
  <div class="lg:w-1/2 bg-slate-900 p-8 lg:p-16 flex items-center justify-center">
    <div class="w-full max-w-sm">
      <div class="mb-8">
        <h2 class="text-2xl font-semibold tracking-tight text-white">Reset password</h2>
        <p class="mt-1 text-slate-400 text-sm">Enter the email associated with your account</p>
      </div>

      <%= form_tag forgot_password_path, class: "space-y-5" do %>
        <div>
          <label for="email" class="block text-sm font-medium text-slate-300 mb-1.5">Email</label>
          <%= email_field_tag :email, nil, id: "email", placeholder: "you@example.com", required: true, class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
        </div>
        <%= submit_tag "Send reset link", class: "w-full bg-teal-600 hover:bg-teal-500 text-white font-medium rounded-lg px-6 py-2.5 transition-colors cursor-pointer text-sm" %>
      <% end %>

      <p class="mt-8 text-center text-sm text-slate-500">
        Remember your password?
        <%= link_to "Sign in", login_path, class: "text-teal-400 hover:text-teal-300 transition-colors font-medium" %>
      </p>
    </div>
  </div>
</div>
