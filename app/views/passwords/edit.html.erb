<% content_for :title, "Set new password - Kubera" %>

<div class="min-h-screen flex flex-col lg:flex-row">
  <%# Brand panel %>
  <div class="lg:w-1/2 bg-slate-950 p-8 lg:p-16 flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-teal-500/10 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-lg">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl bg-teal-600 flex items-center justify-center text-white font-bold text-lg">K</div>
        <span class="text-xl font-semibold tracking-tight text-white">Kubera</span>
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tighter text-white leading-[1.1]">
        Choose a<br>
        <span class="text-teal-400">new password</span>
      </h1>
      <p class="mt-4 text-lg text-slate-400 leading-relaxed max-w-md">
        Make it strong — at least 8 characters with a mix of letters, numbers, and symbols.
      </p>
    </div>
  </div>

  <%# Form panel %>
  <div class="lg:w-1/2 bg-slate-900 p-8 lg:p-16 flex items-center justify-center">
    <div class="w-full max-w-sm">
      <div class="mb-8">
        <h2 class="text-2xl font-semibold tracking-tight text-white">Set new password</h2>
        <p class="mt-1 text-slate-400 text-sm">Must be at least 8 characters</p>
      </div>

      <%= form_tag reset_password_path(params[:token]), method: :put, class: "space-y-5" do %>
        <div>
          <label for="password" class="block text-sm font-medium text-slate-300 mb-1.5">New password</label>
          <%= password_field_tag :password, nil, id: "password", placeholder: "Min. 8 characters", required: true, minlength: 8, class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
        </div>
        <div>
          <label for="password_confirmation" class="block text-sm font-medium text-slate-300 mb-1.5">Confirm new password</label>
          <%= password_field_tag :password_confirmation, nil, id: "password_confirmation", placeholder: "Confirm password", required: true, class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
        </div>
        <%= submit_tag "Reset password", class: "w-full bg-teal-600 hover:bg-teal-500 text-white font-medium rounded-lg px-6 py-2.5 transition-colors cursor-pointer text-sm" %>
      <% end %>
    </div>
  </div>
</div>
