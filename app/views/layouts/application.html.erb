<!DOCTYPE html>
<html class="dark">
<head>
  <title><%= content_for?(:title) ? yield(:title) : "Kubera — Financial Freedom OS" %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)">
  <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="Kubera">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Space+Mono&display=swap" rel="stylesheet">
  <style>
    :root { --font-sans: 'Outfit', system-ui, sans-serif; --font-mono: 'Space Mono', monospace; }
    body { font-family: var(--font-sans); }
    * { scrollbar-width: thin; scrollbar-color: #1e293b transparent; }
  </style>
  <script>
    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.register("/sw.js");
    }
  </script>
</head>
<body class="bg-slate-950 text-slate-100 antialiased min-h-screen">
  <%= yield %>

  <footer class="border-t border-slate-800 mt-16">
    <div class="max-w-7xl mx-auto px-4 py-6 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500">&copy; <%= Time.current.year %> Kubera. Self-hosted.</p>
      <nav class="flex gap-6 text-sm">
        <a href="/privacy" class="text-slate-400 hover:text-white transition-colors">Privacy Policy</a>
        <a href="/security" class="text-slate-400 hover:text-white transition-colors">Security</a>
      </nav>
    </div>
  </footer>
</body>
</html>
