<% content_for :title, "Sign up - Kubera" %>

<div class="min-h-screen flex flex-col lg:flex-row">
  <%# Brand panel %>
  <div class="lg:w-1/2 bg-slate-950 p-8 lg:p-16 flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-teal-500/10 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-lg">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl bg-teal-600 flex items-center justify-center text-white font-bold text-lg">K</div>
        <span class="text-xl font-semibold tracking-tight text-white">Kubera</span>
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tighter text-white leading-[1.1]">
        Take control<br>
        <span class="text-teal-400">of your finances</span>
      </h1>
      <p class="mt-4 text-lg text-slate-400 leading-relaxed max-w-md">
        Join Kubera and start tracking expenses, managing investments, and building wealth.
      </p>
    </div>
  </div>

  <%# Form panel %>
  <div class="lg:w-1/2 bg-slate-900 p-8 lg:p-16 flex items-center justify-center">
    <div class="w-full max-w-sm">
      <div class="mb-8">
        <h2 class="text-2xl font-semibold tracking-tight text-white">Create an account</h2>
        <p class="mt-1 text-slate-400 text-sm">Get started in minutes</p>
      </div>

      <% if flash[:alert] %>
        <div class="mb-6 p-3 bg-red-900/30 border border-red-800/50 rounded-lg text-red-300 text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with model: @user, url: register_path, class: "space-y-4" do |f| %>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= f.label :first_name, class: "block text-sm font-medium text-slate-300 mb-1.5" %>
            <%= f.text_field :first_name, required: true, placeholder: "First", class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
          </div>
          <div>
            <%= f.label :last_name, class: "block text-sm font-medium text-slate-300 mb-1.5" %>
            <%= f.text_field :last_name, required: true, placeholder: "Last", class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
          </div>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-slate-300 mb-1.5" %>
          <%= f.email_field :email, required: true, placeholder: "you@example.com", class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-slate-300 mb-1.5" %>
          <%= f.password_field :password, required: true, placeholder: "Min. 8 characters", minlength: 8, class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "block text-sm font-medium text-slate-300 mb-1.5" %>
          <%= f.password_field :password_confirmation, required: true, placeholder: "Confirm password", class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
        </div>

        <%= f.submit "Create account", class: "w-full bg-teal-600 hover:bg-teal-500 text-white font-medium rounded-lg px-6 py-2.5 transition-colors cursor-pointer text-sm" %>

        <div class="relative my-4">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-700/50"></div></div>
          <div class="relative flex justify-center text-xs"><span class="px-3 bg-slate-900 text-slate-500">or continue with</span></div>
        </div>
      <% end %>

      <div class="space-y-3">
        <%= button_to '/auth/google_oauth2', method: :post, class: "w-full flex items-center justify-center gap-3 bg-slate-800 hover:bg-slate-700 text-slate-200 font-medium rounded-lg px-6 py-2.5 transition-colors border border-slate-700/50 text-sm" do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Google
        <% end %>

        <%= button_to '/auth/github', method: :post, class: "w-full flex items-center justify-center gap-3 bg-slate-800 hover:bg-slate-700 text-slate-200 font-medium rounded-lg px-6 py-2.5 transition-colors border border-slate-700/50 text-sm" do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        <% end %>
      </div>

      <p class="mt-8 text-center text-sm text-slate-500">
        Already have an account?
        <%= link_to "Sign in", login_path, class: "text-teal-400 hover:text-teal-300 transition-colors font-medium" %>
      </p>

      <div class="mt-6 text-center">
        <p class="text-xs text-slate-600">
          By signing up, you agree to our
          <%= link_to "Privacy Policy", privacy_path, class: "underline hover:text-slate-400" %>
          and
          <%= link_to "Terms of Service", terms_path, class: "underline hover:text-slate-400" %>.
        </p>
      </div>
    </div>
  </div>
</div>
