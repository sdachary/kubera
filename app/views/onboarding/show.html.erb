<div class="min-h-screen bg-slate-950 flex items-center justify-center px-4">
  <div class="w-full max-w-lg">
    <div class="flex items-center gap-3 mb-8 justify-center">
      <div class="w-10 h-10 rounded-xl bg-teal-600 flex items-center justify-center text-white font-bold text-lg">K</div>
      <span class="text-xl font-semibold tracking-tight text-white">Kubera</span>
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8">
      <h1 class="text-2xl font-bold tracking-tight text-white">Welcome to Kubera</h1>
      <p class="text-slate-400 text-sm mt-1 mb-6">Let's get you set up</p>

      <%= form_with model: current_user, url: onboarding_path, method: :put, class: "space-y-5" do |f| %>
        <% if flash[:alert] %>
          <div class="p-3 bg-red-900/30 border border-red-800/50 rounded-lg text-red-300 text-sm"><%= flash[:alert] %></div>
        <% end %>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= f.label :first_name, "First name", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
            <%= f.text_field :first_name, required: true, class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
          </div>
          <div>
            <%= f.label :last_name, "Last name", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
            <%= f.text_field :last_name, class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
          </div>
        </div>

        <div>
          <%= f.label :currency, "Preferred currency", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
          <%= f.select :currency, options_for_select(Currency.active.pluck(:code, :code), current_user.currency), {}, class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
        </div>

        <div>
          <%= f.label :theme, "Theme", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
          <%= f.select :theme, options_for_select([["Dark", "dark"], ["Light", "light"]], current_user.theme), {}, class: "w-full px-4 py-2.5 bg-slate-800/50 border border-slate-700 rounded-lg text-white focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500 outline-none transition-colors text-sm" %>
        </div>

        <div class="space-y-3 border-t border-slate-800 pt-5">
          <p class="text-sm font-medium text-slate-200">Data Consent</p>
          <p class="text-xs text-slate-500">Under the DPDP Act 2023, we need your explicit consent for the following purposes. These can be changed anytime in Privacy Settings.</p>

          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" name="consent_financial_tracking" checked class="mt-0.5 w-4 h-4 rounded border-slate-600 bg-slate-800 text-teal-600 focus:ring-teal-500/50">
            <div>
              <span class="text-sm text-slate-200">Financial Tracking</span>
              <p class="text-xs text-slate-500">Record and manage transactions, expenses, and income</p>
            </div>
          </label>

          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" name="consent_trip_data" checked class="mt-0.5 w-4 h-4 rounded border-slate-600 bg-slate-800 text-teal-600 focus:ring-teal-500/50">
            <div>
              <span class="text-sm text-slate-200">Trip Data</span>
              <p class="text-xs text-slate-500">Store trip plans, expenses, and member information</p>
            </div>
          </label>

          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" name="consent_email_updates" class="mt-0.5 w-4 h-4 rounded border-slate-600 bg-slate-800 text-teal-600 focus:ring-teal-500/50">
            <div>
              <span class="text-sm text-slate-200">Email Updates</span>
              <p class="text-xs text-slate-500">Receive account notifications, reports, and reminders</p>
            </div>
          </label>

          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" name="consent_marketing" class="mt-0.5 w-4 h-4 rounded border-slate-600 bg-slate-800 text-teal-600 focus:ring-teal-500/50">
            <div>
              <span class="text-sm text-slate-200">Marketing</span>
              <p class="text-xs text-slate-500">Receive product updates and promotional content</p>
            </div>
          </label>

          <p class="text-xs text-slate-600 mt-2">
            By clicking Get Started, you confirm you are 18 years or older and agree to our
            <%= link_to "Privacy Policy", privacy_path, class: "text-teal-400 hover:text-teal-300 underline" %>.
          </p>
        </div>

        <%= f.submit "Get Started", class: "w-full bg-teal-600 hover:bg-teal-500 text-white font-medium rounded-lg px-6 py-2.5 transition-colors cursor-pointer text-sm" %>
      <% end %>
    </div>
  </div>
</div>
