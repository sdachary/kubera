<div class="min-h-screen flex items-center justify-center bg-gray-950 px-4">
  <div class="max-w-md w-full">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-white">Welcome to Kubera</h1>
      <p class="text-gray-400 mt-2">Let's get you set up</p>
    </div>

    <%= form_with model: current_user, url: onboarding_path, method: :put, class: "space-y-6" do |f| %>
      <% if flash[:alert] %>
        <div class="bg-red-900/50 text-red-200 px-4 py-3 rounded-lg text-sm"><%= flash[:alert] %></div>
      <% end %>

      <div>
        <%= f.label :first_name, "First name", class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.text_field :first_name, required: true, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-white placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.label :last_name, "Last name", class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.text_field :last_name, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-white placeholder-gray-500 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.label :currency, "Preferred currency", class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.select :currency, options_for_select(Currency.active.pluck(:code, :code), current_user.currency), {}, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.label :theme, "Theme", class: "block text-sm font-medium text-gray-300 mb-1" %>
        <%= f.select :theme, options_for_select([["Dark", "dark"], ["Light", "light"]], current_user.theme), {}, class: "w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500" %>
      </div>

      <%= f.submit "Get Started", class: "w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-white font-medium hover:bg-indigo-500 transition cursor-pointer" %>
    <% end %>
  </div>
</div>
