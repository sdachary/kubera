<div class="space-y-6">
  <!-- Header / Summary Section -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
      <p class="text-sm font-medium text-gray-500 uppercase tracking-wider">Total Debt</p>
      <p class="mt-2 text-3xl font-bold text-red-600"><%= number_to_currency(total_debt, unit: "₹", precision: 0) %></p>
      <div class="mt-4 flex items-center text-sm">
        <span class="text-gray-400">Target Freedom: <%= debt_free_date.strftime("%b %Y") %></span>
      </div>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
      <p class="text-sm font-medium text-gray-500 uppercase tracking-wider">Investments</p>
      <p class="mt-2 text-3xl font-bold text-green-600"><%= number_to_currency(total_investments, unit: "₹", precision: 0) %></p>
      <div class="mt-4 flex items-center text-sm text-green-600">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
        <span>Growing at ~12%</span>
      </div>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
      <p class="text-sm font-medium text-gray-500 uppercase tracking-wider">Net Worth</p>
      <p class="mt-2 text-3xl font-bold text-indigo-600"><%= number_to_currency(net_worth, unit: "₹", precision: 0) %></p>
      <div class="mt-4 w-full bg-gray-200 rounded-full h-1.5">
        <div class="bg-indigo-600 h-1.5 rounded-full" style="width: <%= payoff_progress %>%"></div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Current Debts & Payoff Timeline -->
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
      <h3 class="text-lg font-bold text-gray-900 mb-6 flex items-center">
        <svg class="w-5 h-5 mr-2 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        Payoff Timeline
      </h3>
      <div class="space-y-4">
        <% if @debts.any? %>
          <% @debts.each do |debt| %>
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="font-medium text-gray-700"><%= debt.respond_to?(:name) ? debt.name : "Debt" %>: <%= number_to_currency(debt.amount, unit: "₹", precision: 0) %></span>
                <span class="text-gray-500"><%= (debt.respond_to?(:debt_free_date) ? debt.debt_free_date : Date.today).strftime("%b %Y") %></span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-2">
                <% progress = debt.respond_to?(:progress_percentage) ? debt.progress_percentage : rand(20..80) %>
                <div class="bg-red-500 h-2 rounded-full" style="width: <%= progress %>%"></div>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-gray-500 text-sm italic">No active debts found.</p>
        <% end %>
      </div>
      <div class="mt-8 p-4 bg-red-50 rounded-lg">
        <p class="text-sm text-red-800">
          <span class="font-bold">Insight:</span> Increasing monthly payments by ₹5,000 could make you debt-free 4 months earlier.
        </p>
      </div>
    </div>

    <!-- Investment Growth Projection -->
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
      <h3 class="text-lg font-bold text-gray-900 mb-6 flex items-center">
        <svg class="w-5 h-5 mr-2 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
        Investment Growth
      </h3>
      <div class="relative h-48 bg-gray-50 rounded-lg overflow-hidden flex items-end px-4 gap-2">
        <!-- Simplified CSS Chart -->
        <% [40, 55, 45, 70, 85, 95].each do |height| %>
          <div class="flex-1 bg-green-200 hover:bg-green-300 transition-colors rounded-t" style="height: <%= height %>%"></div>
        <% end %>
      </div>
      <div class="mt-6 grid grid-cols-2 gap-4">
        <div class="text-center p-3 bg-gray-50 rounded-lg">
          <p class="text-xs text-gray-500 uppercase">Monthly SIP</p>
          <p class="font-bold text-gray-900">₹ 25,000</p>
        </div>
        <div class="text-center p-3 bg-gray-50 rounded-lg">
          <p class="text-xs text-gray-500 uppercase">Est. 10Y Value</p>
          <p class="font-bold text-gray-900">₹ 45.2 L</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Net Worth Trajectory -->
  <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
    <h3 class="text-lg font-bold text-gray-900 mb-6 flex items-center">
      <svg class="w-5 h-5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
      Net Worth Trajectory
    </h3>
    <% if @net_worth_history.any? %>
      <div class="h-64 flex items-end justify-between px-2 border-b border-l border-gray-200">
        <% max_val = @net_worth_history.map(&:to_f).max || 1.0 %>
        <% @net_worth_history.each_with_index do |value, i| %>
          <div class="w-full mx-1 bg-indigo-500 rounded-t relative group" style="height: <%= [(value.to_f / max_val * 100), 5].max %>%">
            <div class="absolute -top-8 left-1/2 transform -translate-x-1/2 bg-gray-800 text-white text-[10px] px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-10">
              <%= number_to_currency(value, unit: "₹", precision: 0) %>
            </div>
          </div>
        <% end %>
      </div>
      <div class="flex justify-between mt-2 text-xs text-gray-400">
        <span>6 Months Ago</span>
        <span>Today</span>
      </div>
    <% else %>
      <div class="h-64 flex items-center justify-center bg-gray-50 rounded-lg border border-dashed border-gray-300">
        <p class="text-gray-400">Not enough data to show trajectory</p>
      </div>
    <% end %>
  </div>
</div>
