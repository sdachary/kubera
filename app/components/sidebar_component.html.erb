<aside class="fixed left-0 top-0 flex flex-col w-64 h-screen bg-white border-r border-gray-200 dark:bg-gray-900 dark:border-gray-800">
  <div class="flex items-center h-16 px-6 border-b border-gray-200 dark:border-gray-800">
    <span class="text-xl font-bold text-blue-600 dark:text-blue-400">Kubera</span>
  </div>

  <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
    <% nav_items.each do |item| %>
      <%= link_to item[:path],
            class: "flex items-center gap-3 px-3 py-2 text-sm font-medium rounded-lg transition-colors
                   #{active?(item[:path])
                     ? 'bg-blue-50 text-blue-700 dark:bg-blue-900/20 dark:text-blue-400'
                     : 'text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800'}" do %>
        <%= lucide_icon item[:icon], class: "w-5 h-5 shrink-0" %>
        <span><%= item[:name] %></span>
      <% end %>
    <% end %>
  </nav>

  <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-800">
    <p class="text-xs text-gray-500 dark:text-gray-400">Personal Finance</p>
  </div>
</aside>
