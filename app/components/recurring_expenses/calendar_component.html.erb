<div class="max-w-7xl mx-auto p-6">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Recurring Expenses Calendar</h2>
    <p class="text-gray-600 dark:text-gray-400">Track and manage your monthly recurring expenses</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white"><%= current_month_name %></h3>
        <div class="flex gap-2">
          <button class="p-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
            <%= lucide_icon "chevron-left", class: "w-5 h-5" %>
          </button>
          <button class="p-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
            <%= lucide_icon "chevron-right", class: "w-5 h-5" %>
          </button>
        </div>
      </div>

      <div class="grid grid-cols-7 gap-1 mb-2">
        <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |day| %>
          <div class="text-center text-xs font-medium text-gray-500 dark:text-gray-400 py-2"><%= day %></div>
        <% end %>
      </div>

      <div class="grid grid-cols-7 gap-1">
        <% first_day_of_month.times do %>
          <div class="h-24 p-1 border border-gray-100 dark:border-gray-700 rounded"></div>
        <% end %>

        <% (1..days_in_month).each do |day| %>
          <div class="h-24 p-1 border border-gray-200 dark:border-gray-700 rounded hover:bg-gray-50 dark:hover:bg-gray-700 <%= day == @selected_date.day ? 'bg-blue-50 dark:bg-blue-900/20 border-blue-300' : '' %>">
            <div class="text-xs font-medium text-gray-700 dark:text-gray-300 mb-1"><%= day %></div>
            <% expenses_for_day(day).each do |expense| %>
              <div class="text-[10px] p-1 mb-0.5 rounded bg-<%= category_color(expense[:category]) %>-100 text-<%= category_color(expense[:category]) %>-700 dark:bg-<%= category_color(expense[:category]) %>-900/30 dark:text-<%= category_color(expense[:category]) %>-400 truncate">
                <%= expense[:name] %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="space-y-6">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Monthly Summary</h3>
        <div class="text-center p-4 bg-red-50 dark:bg-red-900/20 rounded-lg">
          <p class="text-sm text-gray-500 dark:text-gray-400">Total Monthly Expenses</p>
          <p class="text-3xl font-bold text-red-600 dark:text-red-400">₹<%= total_monthly_expenses.to_i %></p>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Upcoming Expenses</h3>
        <div class="space-y-3">
          <% upcoming_expenses.each do |expense| %>
            <div class="flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-<%= category_color(expense[:category]) %>-100 dark:bg-<%= category_color(expense[:category]) %>-900/30 flex items-center justify-center">
                  <%= lucide_icon category_icon(expense[:category]), class: "w-4 h-4 text-#{category_color(expense[:category])}-600 dark:text-#{category_color(expense[:category])}-400" %>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900 dark:text-white"><%= expense[:name] %></p>
                  <p class="text-xs text-gray-500"><%= expense[:frequency].capitalize %></p>
                </div>
              </div>
              <p class="text-sm font-bold text-gray-900 dark:text-white">₹<%= expense[:amount] %></p>
            </div>
          <% end %>
        </div>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Categories</h3>
        <div class="space-y-2">
          <% @expenses.group_by { |e| e[:category] }.each do |category, expenses| %>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-700 dark:text-gray-300"><%= category %></span>
              <span class="text-sm font-medium text-gray-900 dark:text-white">₹<%= expenses.sum { |e| e[:amount] }.to_i %></span>
            </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<% def category_icon(category)
  case category
  when "Entertainment" then "film"
  when "Utilities" then "zap"
  when "Health" then "heart"
  when "Insurance" then "shield"
  when "Investment" then "trending-up"
  else "circle"
  end
end %>
