<div class="px-6 py-4 flex items-center justify-between hover:bg-gray-50 transition-colors">
  <div>
    <div class="text-lg font-medium text-gray-900">EMI for Debt #<%= @debt.id %></div>
    <div class="text-sm text-gray-500">Interest Rate: <%= @debt.interest_rate %>% | Balance: ₹<%= number_with_delimiter(@debt.amount) %></div>
  </div>
  <div class="text-right">
    <div class="text-lg font-bold text-red-600">₹<%= number_with_delimiter(@debt.emi_amount) %>/mo</div>
    <div class="text-xs text-gray-400">Next Due: <%= @debt.due_date || "N/A" %></div>
  </div>
</div>
