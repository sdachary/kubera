<div class="max-w-7xl mx-auto p-6">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Portfolio Dashboard</h2>
    <p class="text-gray-600 dark:text-gray-400">Track your investments and performance</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Total Investment</span>
        <%= lucide_icon "wallet", class: "w-5 h-5 text-gray-400" %>
      </div>
      <p class="text-2xl font-bold text-gray-900 dark:text-white">₹<%= @total_investment.to_i %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Current Value</span>
        <%= lucide_icon "trending-up", class: "w-5 h-5 text-gray-400" %>
      </div>
      <p class="text-2xl font-bold text-gray-900 dark:text-white">₹<%= @current_value.to_i %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Profit/Loss</span>
        <%= lucide_icon @profit_loss >= 0 ? "arrow-up-right" : "arrow-down-right", class: "w-5 h-5 #{@profit_loss >= 0 ? 'text-green-500' : 'text-red-500'}" %>
      </div>
      <p class="text-2xl font-bold <%= @profit_loss >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">₹<%= @profit_loss.to_i %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Returns</span>
        <%= lucide_icon "percent", class: "w-5 h-5 text-gray-400" %>
      </div>
      <p class="text-2xl font-bold <%= profit_loss_percentage >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>"><%= profit_loss_percentage %>%</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Holdings</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
            <tr>
              <th class="px-4 py-3">Stock</th>
              <th class="px-4 py-3">Qty</th>
              <th class="px-4 py-3">Avg Price</th>
              <th class="px-4 py-3">Invested</th>
              <th class="px-4 py-3">Current</th>
              <th class="px-4 py-3">P&L</th>
            </tr>
          </thead>
          <tbody>
            <% @holdings.each do |holding| %>
              <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-4 py-3">
                  <div>
                    <p class="font-medium text-gray-900 dark:text-white"><%= holding[:symbol] %></p>
                    <p class="text-xs text-gray-500"><%= holding[:name] %></p>
                  </div>
                </td>
                <td class="px-4 py-3"><%= holding[:quantity] %></td>
                <td class="px-4 py-3">₹<%= holding[:avg_price] %></td>
                <td class="px-4 py-3">₹<%= holding[:invested].to_i %></td>
                <td class="px-4 py-3">₹<%= holding[:current_value].to_i %></td>
                <td class="px-4 py-3">
                  <% pl = holding[:current_value] - holding[:invested] %>
                  <span class="<%= pl >= 0 ? 'text-green-600' : 'text-red-600' %>">
                    ₹<%= pl.to_i %> (<%= ((pl / holding[:invested]) * 100).round(2) %>%)
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Asset Allocation</h3>
      <div class="space-y-4">
        <% asset_allocation.each do |allocation| %>
          <div>
            <div class="flex justify-between mb-1">
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300"><%= allocation[:type] %></span>
              <span class="text-sm text-gray-500"><%= allocation[:percentage] %>%</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2.5 dark:bg-gray-700">
              <div class="bg-blue-600 h-2.5 rounded-full" style="width: <%= allocation[:percentage] %>%"></div>
            </div>
            <p class="text-xs text-gray-500 mt-1">₹<%= allocation[:value].to_i %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
