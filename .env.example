# ===========================================================================
# Kubera — Environment Variables
# ===========================================================================
#
# Copy this file to .env and fill in your values.
# The installer does this automatically.
#
# cp .env.example .env
#
# ===========================================================================


# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

SELF_HOSTED=true
ONBOARDING_STATE=open

# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=


# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------

POSTGRES_USER=kubera_user
POSTGRES_PASSWORD=
POSTGRES_DB=kubera_production
DB_HOST=db
DB_PORT=5432


# ---------------------------------------------------------------------------
# PORT
# ---------------------------------------------------------------------------

PORT=3000


# ---------------------------------------------------------------------------
# AI ASSISTANT
# ---------------------------------------------------------------------------
#
# Works with ANY OpenAI-compatible endpoint — free models work great.
#
# OpenRouter (recommended — free models available)
#   OPENAI_URI_BASE=https://openrouter.ai/api/v1
#   OPENAI_ACCESS_TOKEN=sk-or-...
#   OPENAI_MODEL=meta-llama/llama-3.1-70b-instruct   ← free
#   Get key: https://openrouter.ai/keys
#
# Ollama (fully local, no API key)
#   OPENAI_URI_BASE=http://host.docker.internal:11434/v1
#   OPENAI_ACCESS_TOKEN=ollama
#   OPENAI_MODEL=llama3.1
#
# Anthropic
#   OPENAI_URI_BASE=https://api.anthropic.com/v1
#   OPENAI_ACCESS_TOKEN=sk-ant-...
#   OPENAI_MODEL=claude-3-5-sonnet-20241022
#
# OpenAI
#   OPENAI_URI_BASE=https://api.openai.com/v1
#   OPENAI_ACCESS_TOKEN=sk-...
#   OPENAI_MODEL=gpt-4o-mini

OPENAI_URI_BASE=
OPENAI_ACCESS_TOKEN=
OPENAI_MODEL=


# ---------------------------------------------------------------------------
# MARKET DATA
# ---------------------------------------------------------------------------

# Yahoo Finance is free, no key needed (default)
EXCHANGE_RATE_PROVIDER=yahoo_finance
SECURITIES_PROVIDER=yahoo_finance

# Optional: Twelve Data (free tier: 800 req/day) — https://twelvedata.com
# EXCHANGE_RATE_PROVIDER=twelve_data
# SECURITIES_PROVIDER=twelve_data
# TWELVE_DATA_API_KEY=


# ---------------------------------------------------------------------------
# EMAIL — optional, needed for password reset & reports
# ---------------------------------------------------------------------------
# Resend.com recommended (free tier: 3000/month) — https://resend.com

SMTP_ADDRESS=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_ENABLED=true
EMAIL_SENDER=


# ---------------------------------------------------------------------------
# BRANDING
# ---------------------------------------------------------------------------

PRODUCT_NAME=Kubera
BRAND_NAME=Kubera


# ---------------------------------------------------------------------------
# SSL — only for public internet deployments
# ---------------------------------------------------------------------------

RAILS_ASSUME_SSL=false
# APP_DOMAIN=kubera.yourdomain.com


# ---------------------------------------------------------------------------
# REDIS
# ---------------------------------------------------------------------------

REDIS_URL=redis://redis:6379/1
