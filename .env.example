# Kubera — Environment Configuration
# Copy this to .env and fill in values.
# The app reads these vars directly (not Rails credentials).
#
# ── Naming Convention ────────────────────────
# Kubera follows Rails ENV conventions (SECRET_KEY_BASE, POSTGRES_*, etc.)
# No project prefix needed — keep as-is.
# ─────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────
SECRET_KEY_BASE=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── Optional ──────────────────────────────────────────────────────────
POSTGRES_DB=kubera_production
DB_HOST=localhost
DB_PORT=5432
PORT=3002
