# Kubera — Environment Configuration
# Copy this to .env and fill in values.
# The app reads these vars directly (not Rails credentials).

# ── Required ──────────────────────────────────────────────────────────
SECRET_KEY_BASE=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── Optional ──────────────────────────────────────────────────────────
POSTGRES_DB=kubera_production
DB_HOST=localhost
DB_PORT=5432
PORT=3002
