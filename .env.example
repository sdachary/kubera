# Kubera — Environment Configuration
# Copy this to .env and fill in values.

# ── Required ──────────────────────────────────────────────────────────
SECRET_KEY_BASE=
POSTGRES_PASSWORD=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_DOMAIN=

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_USER=kubera
POSTGRES_DB=kubera_production
DB_HOST=localhost
DB_PORT=5432

# ── Server ────────────────────────────────────────────────────────────
PORT=3002
RAILS_ENV=production
RAILS_MAX_THREADS=3
WEB_CONCURRENCY=1
BINDING=0.0.0.0

# ── SSL ───────────────────────────────────────────────────────────────
# Set true only if Nginx/Caddy handles SSL termination
RAILS_FORCE_SSL=false
RAILS_ASSUME_SSL=false

# ── Redis / Sidekiq ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SIDEKIQ_WEB_USERNAME=kubera
SIDEKIQ_WEB_PASSWORD=kubera

# ── SMTP (for emails & passwordless login) ────────────────────────────
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_ENABLED=false

# ── Rails Encryption (for encrypted columns) ──────────────────────────
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ── Other ──────────────────────────────────────────────────────────────
CORS_ORIGINS=*
