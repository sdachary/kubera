# ===========================================================================
# Kubera — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env
# ===========================================================================

# REQUIRED
SECRET_KEY_BASE=
# Generate with: openssl rand -hex 64

# DATABASE
POSTGRES_USER=kubera_user
POSTGRES_PASSWORD=kubera_password
POSTGRES_DB=kubera_production
DB_HOST=localhost
DB_PORT=5432

# PORT
PORT=3000

# AI ASSISTANT (optional — works without it with smart fallback responses)
# Works with ANY OpenAI-compatible endpoint:
#
# OpenRouter (recommended — free models available)
#   OPENAI_URI_BASE=https://openrouter.ai/api/v1
#   OPENAI_ACCESS_TOKEN=sk-or-...
#   OPENAI_MODEL=google/gemini-2.0-flash-lite-001   ← free
#   Get key: https://openrouter.ai/keys
#
# Ollama (fully local, no API key)
#   OPENAI_URI_BASE=http://localhost:11434/v1
#   OPENAI_ACCESS_TOKEN=ollama
#   OPENAI_MODEL=llama3.1

OPENAI_URI_BASE=https://openrouter.ai/api/v1
OPENAI_ACCESS_TOKEN=
OPENAI_MODEL=google/gemini-2.0-flash-lite-001
